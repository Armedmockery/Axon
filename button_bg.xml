<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Pressed state -->
    <item android:state_pressed="true">
        <layer-list>
            <!-- Base rounded background with 1dp stroke on all sides -->
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#2E2D2D"/>
                    <corners android:radius="17dp"/>
                </shape>
            </item>

            <!-- Inner fill - slightly darker when pressed -->
            <item android:top="1.5dp" android:left="1.5dp" android:right="1.5dp" android:bottom="3dp">
                <shape android:shape="rectangle">
                    <solid android:color="#E05546"/> <!-- Darker shade of #FB695A -->
                    <corners android:radius="15dp"/>
                </shape>
            </item>
        </layer-list>
    </item>

    <!-- Default state -->
    <item>
        <layer-list>
            <!-- Base rounded background with 1dp stroke on all sides -->
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#2E2D2D"/>
                    <corners android:radius="17dp"/>
                </shape>
            </item>

            <!-- Inner fill (creates border effect) -->
            <item android:top="1.5dp" android:left="1.5dp" android:right="1.5dp" android:bottom="3dp">
                <shape android:shape="rectangle">
                    <solid android:color="#FB695A"/>
                    <corners android:radius="15dp"/>
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
